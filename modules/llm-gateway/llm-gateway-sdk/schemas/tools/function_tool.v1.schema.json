{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gts://gts.x.llmgw.tools.tool.v1~x.llmgw.tools.function_tool.v1~",
  "title": "FunctionTool",
  "description": "Function tool definition following Open Responses protocol.",
  "allOf": [
    { "$ref": "gts://gts.x.llmgw.tools.tool.v1~" },
    {
      "properties": {
        "type": {
          "type": "string",
          "const": "function",
          "default": "function",
          "description": "Tool type discriminator."
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64,
          "pattern": "^[a-zA-Z0-9_-]+$",
          "description": "Function name."
        },
        "description": {
          "type": ["string", "null"],
          "description": "Function description for the model."
        },
        "parameters": {
          "oneOf": [
            { "type": "object" },
            { "type": "null" }
          ],
          "description": "JSON Schema for function parameters."
        },
        "strict": {
          "type": ["boolean", "null"],
          "description": "Strict schema enforcement for function arguments."
        }
      },
      "required": ["type", "name"]
    }
  ],
  "unevaluatedProperties": false
}
