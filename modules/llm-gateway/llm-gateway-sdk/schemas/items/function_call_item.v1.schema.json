{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gts://gts.x.llmgw.items.item.v1~x.llmgw.items.function_call_item.v1~",
  "title": "FunctionCallItem",
  "description": "Item representing a function call. Used as output when the model invokes a tool, and as input when providing function call context in subsequent requests.",
  "allOf": [
    { "$ref": "gts://gts.x.llmgw.items.item.v1~" },
    {
      "properties": {
        "type": {
          "type": "string",
          "const": "function_call"
        },
        "id": {
          "type": ["string", "null"],
          "description": "Item identifier. Present in output, optional for input."
        },
        "status": {
          "type": ["string", "null"],
          "enum": ["in_progress", "completed", "incomplete", null],
          "description": "Item lifecycle status. Present in output, optional for input."
        },
        "call_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64,
          "description": "Function call identifier for correlating with function_call_output."
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64,
          "pattern": "^[a-zA-Z0-9_-]+$",
          "description": "Function name."
        },
        "arguments": {
          "type": "string",
          "maxLength": 10485760,
          "description": "Function arguments as JSON string."
        }
      },
      "required": ["type", "call_id", "name", "arguments"]
    }
  ]
}
