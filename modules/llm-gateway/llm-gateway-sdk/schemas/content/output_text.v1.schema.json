{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gts://gts.x.llmgw.content.output_text.v1~",
  "title": "OutputText",
  "description": "Output text content part with annotations and optional logprobs",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "const": "output_text",
      "default": "output_text",
      "description": "Content type discriminator"
    },
    "text": {
      "type": "string",
      "description": "Generated text content"
    },
    "annotations": {
      "type": "array",
      "items": {
        "$ref": "gts://gts.x.llmgw.content.url_citation.v1~"
      },
      "description": "Text annotations (citations, links)"
    },
    "logprobs": {
      "type": ["array", "null"],
      "items": {
        "type": "object",
        "properties": {
          "token": { "type": "string" },
          "logprob": { "type": "number" },
          "bytes": {
            "type": "array",
            "items": { "type": "integer", "minimum": 0, "maximum": 255 }
          },
          "top_logprobs": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "token": { "type": "string" },
                "logprob": { "type": "number" },
                "bytes": {
                  "type": "array",
                  "items": { "type": "integer", "minimum": 0, "maximum": 255 }
                }
              },
              "required": ["token", "logprob", "bytes"]
            }
          }
        },
        "required": ["token", "logprob", "bytes", "top_logprobs"]
      },
      "description": "Token log probabilities (when requested via include parameter)"
    }
  },
  "required": ["type", "text", "annotations"],
  "additionalProperties": false
}
