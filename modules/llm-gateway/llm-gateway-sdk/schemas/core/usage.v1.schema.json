{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gts://gts.x.llmgw.core.usage.v1~",
  "title": "Usage",
  "description": "Token usage information following Open Responses protocol",
  "type": "object",
  "properties": {
    "input_tokens": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of input tokens consumed"
    },
    "output_tokens": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of output tokens generated"
    },
    "total_tokens": {
      "type": "integer",
      "minimum": 0,
      "description": "Total tokens (input + output)"
    },
    "input_tokens_details": {
      "type": "object",
      "properties": {
        "cached_tokens": {
          "type": "integer",
          "minimum": 0,
          "description": "Tokens served from cache"
        }
      },
      "required": ["cached_tokens"],
      "description": "Breakdown of input token usage"
    },
    "output_tokens_details": {
      "type": "object",
      "properties": {
        "reasoning_tokens": {
          "type": "integer",
          "minimum": 0,
          "description": "Tokens used for reasoning"
        }
      },
      "required": ["reasoning_tokens"],
      "description": "Breakdown of output token usage"
    }
  },
  "required": ["input_tokens", "output_tokens", "total_tokens", "input_tokens_details", "output_tokens_details"],
  "additionalProperties": false
}
