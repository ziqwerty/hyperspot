{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gts://gts.x.llmgw.content.url_citation.v1~",
  "title": "UrlCitation",
  "description": "URL citation annotation within output text",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "const": "url_citation",
      "description": "Annotation type discriminator"
    },
    "url": {
      "type": "string",
      "format": "uri",
      "description": "Cited URL"
    },
    "title": {
      "type": "string",
      "description": "Citation title"
    },
    "start_index": {
      "type": "integer",
      "minimum": 0,
      "description": "Start character index in the output text"
    },
    "end_index": {
      "type": "integer",
      "minimum": 0,
      "description": "End character index in the output text (must be >= start_index)"
    }
  },
  "required": ["type", "url", "title", "start_index", "end_index"],
  "additionalProperties": false
}
