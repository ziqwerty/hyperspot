{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gts://gts.x.llmgw.content.input_video.v1~",
  "title": "InputVideo",
  "description": "Input video content part with FileStorage URL or file ID",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "const": "input_video",
      "description": "Content type discriminator"
    },
    "url": {
      "type": "string",
      "format": "uri",
      "description": "Video URL (FileStorage or external)"
    },
    "file_id": {
      "type": "string",
      "description": "FileStorage file identifier"
    }
  },
  "required": ["type"],
  "anyOf": [
    { "required": ["url"] },
    { "required": ["file_id"] }
  ],
  "additionalProperties": false
}
