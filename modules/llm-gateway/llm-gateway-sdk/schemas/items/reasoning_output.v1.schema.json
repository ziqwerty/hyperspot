{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gts://gts.x.llmgw.items.item.v1~x.llmgw.items.reasoning_output.v1~",
  "title": "ReasoningOutput",
  "description": "Output item containing the model's reasoning trace.",
  "allOf": [
    { "$ref": "gts://gts.x.llmgw.items.item.v1~" },
    {
      "properties": {
        "type": {
          "type": "string",
          "const": "reasoning"
        },
        "id": {
          "type": "string",
          "description": "Unique item identifier."
        },
        "summary": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": { "type": "string", "const": "summary_text" },
              "text": { "type": "string", "maxLength": 10485760 }
            },
            "required": ["type", "text"]
          },
          "description": "Human-readable reasoning summary."
        },
        "content": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "type": { "type": "string", "const": "reasoning_text" },
                  "text": { "type": "string", "maxLength": 10485760 }
                },
                "required": ["type", "text"]
              }
            }
          ],
          "description": "Reasoning text content (may be null if provider does not expose raw reasoning)."
        },
        "encrypted_content": {
          "type": ["string", "null"],
          "description": "Encrypted reasoning content for roundtripping."
        }
      },
      "required": ["type", "id"]
    }
  ]
}
