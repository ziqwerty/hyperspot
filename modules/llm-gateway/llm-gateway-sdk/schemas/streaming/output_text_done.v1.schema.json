{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gts://gts.x.llmgw.streaming.event.v1~x.llmgw.streaming.output_text_done.v1~",
  "title": "Response output text done event",
  "description": "A streaming event indicating output text was completed.",
  "allOf": [
    { "$ref": "gts://gts.x.llmgw.streaming.event.v1~" },
    {
      "properties": {
        "type": {
          "type": "string",
          "const": "response.output_text.done"
        },
        "item_id": {
          "type": "string",
          "description": "The ID of the item that was updated."
        },
        "output_index": {
          "type": "integer",
          "minimum": 0,
          "description": "The index of the output item that was updated."
        },
        "content_index": {
          "type": "integer",
          "minimum": 0,
          "description": "The index of the content part that was completed."
        },
        "text": {
          "type": "string",
          "description": "The final text that was emitted."
        },
        "logprobs": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "token": { "type": "string" },
              "logprob": { "type": "number" },
              "bytes": { "type": "array", "items": { "type": "integer", "minimum": 0, "maximum": 255 } },
              "top_logprobs": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "token": { "type": "string" },
                    "logprob": { "type": "number" },
                    "bytes": { "type": "array", "items": { "type": "integer", "minimum": 0, "maximum": 255 } }
                  },
                  "required": ["token", "logprob"]
                }
              }
            },
            "required": ["token", "logprob", "top_logprobs"]
          },
          "description": "The token log probabilities emitted with the final text, if any."
        }
      },
      "required": ["type", "sequence_number", "item_id", "output_index", "content_index", "text"]
    }
  ]
}
