{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gts://gts.x.llmgw.core.reasoning_config.v1~",
  "title": "ReasoningConfig",
  "description": "Reasoning configuration for models that support extended thinking",
  "type": "object",
  "properties": {
    "effort": {
      "type": ["string", "null"],
      "enum": ["none", "low", "medium", "high", "xhigh", null],
      "description": "Reasoning effort level"
    },
    "summary": {
      "type": ["string", "null"],
      "enum": ["concise", "detailed", "auto", null],
      "description": "Reasoning summary verbosity"
    }
  },
  "additionalProperties": false
}
