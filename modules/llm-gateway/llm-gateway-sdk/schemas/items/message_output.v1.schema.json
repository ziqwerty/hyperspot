{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gts://gts.x.llmgw.items.item.v1~x.llmgw.items.message_output.v1~",
  "title": "MessageOutput",
  "description": "Output item containing the model's message response.",
  "allOf": [
    { "$ref": "gts://gts.x.llmgw.items.item.v1~" },
    {
      "properties": {
        "type": {
          "type": "string",
          "const": "message"
        },
        "id": {
          "type": "string",
          "description": "Unique item identifier."
        },
        "status": {
          "type": "string",
          "enum": ["in_progress", "completed", "incomplete"],
          "description": "Item lifecycle status."
        },
        "role": {
          "type": "string",
          "enum": ["assistant"],
          "description": "Message author role."
        },
        "content": {
          "type": "array",
          "items": {
            "$ref": "gts://gts.x.llmgw.content.output_content_part.v1~"
          },
          "description": "Output content parts."
        }
      },
      "required": ["type", "id", "status", "role", "content"]
    }
  ]
}
