{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gts://gts.x.llmgw.streaming.event.v1~x.llmgw.streaming.error.v1~",
  "title": "Error event",
  "description": "A streaming event indicating an error was emitted.",
  "allOf": [
    { "$ref": "gts://gts.x.llmgw.streaming.event.v1~" },
    {
      "properties": {
        "type": {
          "type": "string",
          "const": "error"
        },
        "error": {
          "$ref": "gts://gts.x.llmgw.core.error.v1~",
          "description": "The error payload that was emitted."
        }
      },
      "required": ["type", "sequence_number", "error"]
    }
  ]
}
