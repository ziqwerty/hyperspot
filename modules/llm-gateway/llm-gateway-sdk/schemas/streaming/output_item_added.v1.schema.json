{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gts://gts.x.llmgw.streaming.event.v1~x.llmgw.streaming.output_item_added.v1~",
  "title": "Response output item added event",
  "description": "A streaming event indicating an output item was added to the response.",
  "allOf": [
    { "$ref": "gts://gts.x.llmgw.streaming.event.v1~" },
    {
      "properties": {
        "type": {
          "type": "string",
          "const": "response.output_item.added"
        },
        "output_index": {
          "type": "integer",
          "minimum": 0,
          "description": "The index of the output item that was added."
        },
        "item": {
          "$ref": "gts://gts.x.llmgw.items.item.v1~",
          "description": "The output item that was added."
        }
      },
      "required": ["type", "sequence_number", "output_index", "item"]
    }
  ]
}
