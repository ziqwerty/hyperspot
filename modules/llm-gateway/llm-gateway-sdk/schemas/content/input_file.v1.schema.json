{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gts://gts.x.llmgw.content.input_file.v1~",
  "title": "InputFile",
  "description": "Input file/document content part",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "const": "input_file",
      "description": "Content type discriminator"
    },
    "filename": {
      "type": ["string", "null"],
      "description": "Original filename for display"
    },
    "file_data": {
      "type": "string",
      "maxLength": 33554432,
      "description": "Base64-encoded file data"
    },
    "file_url": {
      "type": "string",
      "description": "File URL"
    },
    "file_id": {
      "type": "string",
      "description": "FileStorage file identifier (CyberFabric extension)"
    }
  },
  "required": ["type"],
  "anyOf": [
    { "required": ["file_data"] },
    { "required": ["file_url"] },
    { "required": ["file_id"] }
  ],
  "additionalProperties": false
}
