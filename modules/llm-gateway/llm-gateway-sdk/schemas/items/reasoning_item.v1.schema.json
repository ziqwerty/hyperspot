{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gts://gts.x.llmgw.items.item.v1~x.llmgw.items.reasoning_item.v1~",
  "title": "ReasoningItem",
  "description": "Input item providing reasoning context from a previous response.",
  "allOf": [
    { "$ref": "gts://gts.x.llmgw.items.item.v1~" },
    {
      "properties": {
        "id": {
          "type": ["string", "null"],
          "description": "Optional item identifier."
        },
        "type": {
          "type": "string",
          "const": "reasoning"
        },
        "summary": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": { "type": "string", "const": "summary_text" },
              "text": { "type": "string", "maxLength": 10485760 }
            },
            "required": ["type", "text"]
          },
          "description": "Reasoning summary parts."
        },
        "content": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "type": { "type": "string", "const": "reasoning_text" },
                  "text": { "type": "string", "maxLength": 10485760 }
                },
                "required": ["type", "text"]
              }
            }
          ],
          "description": "Reasoning text content (null if provider does not expose raw reasoning)."
        },
        "encrypted_content": {
          "type": ["string", "null"],
          "description": "Encrypted reasoning content for providers that do not expose raw reasoning."
        }
      },
      "required": ["type", "summary"]
    }
  ]
}
