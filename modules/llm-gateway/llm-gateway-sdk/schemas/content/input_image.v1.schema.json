{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gts://gts.x.llmgw.content.input_image.v1~",
  "title": "InputImage",
  "description": "Input image content part. At least one of image_url or file_id must be provided.",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "const": "input_image",
      "default": "input_image",
      "description": "Content type discriminator"
    },
    "image_url": {
      "type": ["string", "null"],
      "maxLength": 20971520,
      "description": "Image URL or base64 data URI"
    },
    "file_id": {
      "type": ["string", "null"],
      "description": "FileStorage file identifier (CyberFabric extension)"
    },
    "detail": {
      "type": ["string", "null"],
      "enum": ["low", "high", "auto", null],
      "description": "Image detail level for vision models"
    }
  },
  "required": ["type"],
  "additionalProperties": false
}
