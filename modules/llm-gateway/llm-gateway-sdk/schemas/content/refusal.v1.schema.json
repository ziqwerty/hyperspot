{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gts://gts.x.llmgw.content.refusal.v1~",
  "title": "Refusal",
  "description": "Output content part indicating the model refused to generate content",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "const": "refusal",
      "default": "refusal",
      "description": "Content type discriminator"
    },
    "refusal": {
      "type": "string",
      "maxLength": 10485760,
      "description": "Refusal explanation"
    }
  },
  "required": ["type", "refusal"],
  "additionalProperties": false
}
