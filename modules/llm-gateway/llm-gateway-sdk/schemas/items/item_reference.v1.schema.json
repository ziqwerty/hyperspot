{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gts://gts.x.llmgw.items.item.v1~x.llmgw.items.item_reference.v1~",
  "title": "ItemReference",
  "description": "Reference to an item from a previous response.",
  "allOf": [
    { "$ref": "gts://gts.x.llmgw.items.item.v1~" },
    {
      "properties": {
        "type": {
          "type": "string",
          "const": "item_reference",
          "description": "Item type discriminator (optional per spec)."
        },
        "id": {
          "type": "string",
          "description": "ID of the referenced item from a previous response."
        }
      },
      "required": ["id"]
    }
  ]
}
