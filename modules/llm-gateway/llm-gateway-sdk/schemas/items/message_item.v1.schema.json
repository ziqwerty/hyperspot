{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gts://gts.x.llmgw.items.item.v1~x.llmgw.items.message_item.v1~",
  "title": "MessageItem",
  "description": "Input message item with role and content parts.",
  "allOf": [
    { "$ref": "gts://gts.x.llmgw.items.item.v1~" },
    {
      "properties": {
        "id": {
          "type": ["string", "null"],
          "description": "Optional item identifier."
        },
        "type": {
          "type": "string",
          "const": "message"
        },
        "role": {
          "$ref": "gts://gts.x.llmgw.core.role.v1~",
          "description": "Message author role."
        },
        "content": {
          "oneOf": [
            {
              "type": "string",
              "maxLength": 10485760
            },
            {
              "type": "array",
              "items": {
                "$ref": "gts://gts.x.llmgw.content.input_content_part.v1~"
              },
              "minItems": 1
            }
          ],
          "description": "Input content: text string or array of content parts."
        },
        "status": {
          "type": ["string", "null"],
          "description": "Item status."
        }
      },
      "required": ["type", "role", "content"]
    }
  ]
}
