{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gts://gts.x.llmgw.core.text_format.v1~",
  "title": "TextFormat",
  "description": "Response text format configuration",
  "type": "object",
  "properties": {
    "format": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "type": { "type": "string", "const": "text" }
          },
          "required": ["type"],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "type": { "type": "string", "const": "json_object" }
          },
          "required": ["type"],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "type": { "type": "string", "const": "json_schema" },
            "name": { "type": "string", "description": "Schema name" },
            "description": { "type": ["string", "null"], "description": "Schema description" },
            "schema": { "type": ["object", "null"], "description": "JSON Schema definition" },
            "strict": { "type": "boolean", "description": "Strict schema enforcement" }
          },
          "required": ["type", "name", "description", "schema", "strict"],
          "additionalProperties": false
        }
      ],
      "description": "Output format: text, json_object, or json_schema"
    },
    "verbosity": {
      "type": "string",
      "enum": ["low", "medium", "high"],
      "description": "Text verbosity level"
    }
  },
  "required": ["format"],
  "additionalProperties": false
}
