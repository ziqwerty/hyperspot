{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gts://gts.x.llmgw.streaming.event.v1~x.llmgw.streaming.output_item_done.v1~",
  "title": "Response output item done event",
  "description": "A streaming event indicating an output item was completed.",
  "allOf": [
    { "$ref": "gts://gts.x.llmgw.streaming.event.v1~" },
    {
      "properties": {
        "type": {
          "type": "string",
          "const": "response.output_item.done"
        },
        "output_index": {
          "type": "integer",
          "description": "The index of the output item that was completed."
        },
        "item": {
          "oneOf": [
            { "$ref": "gts://gts.x.llmgw.items.item.v1~" },
            { "type": "null" }
          ],
          "description": "The output item that was completed."
        }
      },
      "required": ["type", "sequence_number", "output_index", "item"]
    }
  ]
}
