{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gts://gts.x.llmgw.items.item.v1~x.llmgw.items.function_call_output_item.v1~",
  "title": "FunctionCallOutputItem",
  "description": "Input item providing the result of a function call executed by the consumer.",
  "allOf": [
    { "$ref": "gts://gts.x.llmgw.items.item.v1~" },
    {
      "properties": {
        "id": {
          "type": ["string", "null"],
          "description": "Optional item identifier."
        },
        "type": {
          "type": "string",
          "const": "function_call_output"
        },
        "call_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64,
          "description": "ID of the function_call this output is for."
        },
        "output": {
          "oneOf": [
            {
              "type": "string",
              "maxLength": 10485760
            },
            {
              "type": "array",
              "items": {
                "$ref": "gts://gts.x.llmgw.content.input_content_part.v1~"
              }
            }
          ],
          "description": "Function call result as string or array of content parts."
        },
        "status": {
          "type": ["string", "null"],
          "enum": ["in_progress", "completed", "incomplete", null],
          "description": "Item status."
        }
      },
      "required": ["call_id", "type", "output"]
    }
  ]
}
