{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gts://gts.x.llmgw.tools.tool.v1~x.llmgw.tools.tool_reference.v1~",
  "title": "ToolReference",
  "description": "Reference to a tool schema in Type Registry.",
  "allOf": [
    { "$ref": "gts://gts.x.llmgw.tools.tool.v1~" },
    {
      "properties": {
        "type": {
          "type": "string",
          "const": "reference",
          "description": "Tool type discriminator."
        },
        "schema_id": {
          "type": "string",
          "description": "GTS identifier of the tool schema in Type Registry."
        }
      },
      "required": ["type", "schema_id"]
    }
  ],
  "unevaluatedProperties": false
}
