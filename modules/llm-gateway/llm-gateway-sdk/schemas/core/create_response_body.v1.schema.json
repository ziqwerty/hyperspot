{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gts://gts.x.llmgw.core.create_response_body.v1~",
  "title": "CreateResponseBody",
  "description": "Open Responses protocol request body for creating a response",
  "type": "object",
  "properties": {
    "model": {
      "type": ["string", "null"],
      "description": "Model identifier from Model Registry"
    },
    "input": {
      "oneOf": [
        { "type": "string", "maxLength": 10485760 },
        {
          "type": "array",
          "items": {
            "$ref": "gts://gts.x.llmgw.items.item.v1~"
          }
        },
        { "type": "null" }
      ],
      "description": "Input items, a single text string, or null"
    },
    "instructions": {
      "type": ["string", "null"],
      "description": "System-level instructions for the model"
    },
    "previous_response_id": {
      "type": ["string", "null"],
      "description": "ID of a previous response for context chaining"
    },
    "include": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["reasoning.encrypted_content", "message.output_text.logprobs"]
      },
      "description": "Additional data to include in the response"
    },
    "tools": {
      "type": ["array", "null"],
      "items": {
        "$ref": "gts://gts.x.llmgw.tools.tool.v1~"
      },
      "description": "Available tools for the model"
    },
    "tool_choice": {
      "oneOf": [
        { "type": "string", "enum": ["auto", "required", "none"] },
        {
          "type": "object",
          "properties": {
            "type": { "type": "string", "const": "function" },
            "name": { "type": "string" }
          },
          "required": ["type", "name"]
        }
      ],
      "description": "Tool selection strategy"
    },
    "parallel_tool_calls": {
      "type": ["boolean", "null"],
      "description": "Whether model can issue multiple tool calls in parallel"
    },
    "text": {
      "$ref": "gts://gts.x.llmgw.core.text_format.v1~",
      "description": "Response text format configuration"
    },
    "reasoning": {
      "$ref": "gts://gts.x.llmgw.core.reasoning_config.v1~",
      "description": "Reasoning configuration"
    },
    "temperature": {
      "type": ["number", "null"],
      "description": "Sampling temperature"
    },
    "top_p": {
      "type": ["number", "null"],
      "description": "Nucleus sampling parameter"
    },
    "max_output_tokens": {
      "type": ["integer", "null"],
      "minimum": 16,
      "description": "Maximum output tokens"
    },
    "max_tool_calls": {
      "type": ["integer", "null"],
      "minimum": 1,
      "description": "Maximum number of tool calls"
    },
    "presence_penalty": {
      "type": ["number", "null"],
      "description": "Presence penalty"
    },
    "frequency_penalty": {
      "type": ["number", "null"],
      "description": "Frequency penalty"
    },
    "top_logprobs": {
      "type": ["integer", "null"],
      "minimum": 0,
      "maximum": 20,
      "description": "Number of top log probabilities to return per token"
    },
    "truncation": {
      "type": "string",
      "enum": ["auto", "disabled"],
      "default": "disabled",
      "description": "Context truncation strategy"
    },
    "stream": {
      "type": "boolean",
      "default": false,
      "description": "Enable streaming response via SSE. When true, the response is a stream of events conforming to gts.x.llmgw.streaming.event.v1~ (and its derived types) instead of a single ResponseResource."
    },
    "stream_options": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "include_usage": { "type": "boolean" }
          },
          "additionalProperties": false
        },
        { "type": "null" }
      ],
      "description": "Streaming options"
    },
    "background": {
      "type": "boolean",
      "default": false,
      "description": "Run as background (async) job"
    },
    "store": {
      "type": "boolean",
      "default": true,
      "description": "Whether to store the response for later retrieval"
    },
    "service_tier": {
      "type": "string",
      "enum": ["auto", "default"],
      "default": "auto",
      "description": "Service tier hint for processing priority"
    },
    "metadata": {
      "type": ["object", "null"],
      "additionalProperties": { "type": "string", "maxLength": 512 },
      "propertyNames": { "maxLength": 64 },
      "maxProperties": 16,
      "description": "Key-value metadata (up to 16 pairs, 64 char keys, 512 char values)"
    },
    "safety_identifier": {
      "type": ["string", "null"],
      "maxLength": 64,
      "description": "Safety configuration identifier"
    },
    "prompt_cache_key": {
      "type": ["string", "null"],
      "maxLength": 64,
      "description": "Prompt cache key for reuse across requests"
    }
  },
  "additionalProperties": false
}
