{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gts://gts.x.llmgw.content.input_audio.v1~",
  "title": "InputAudio",
  "description": "Input audio content part with FileStorage URL or inline data",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "const": "input_audio",
      "description": "Content type discriminator"
    },
    "url": {
      "type": "string",
      "format": "uri",
      "description": "Audio URL (FileStorage or external)"
    },
    "data": {
      "type": "string",
      "description": "Base64-encoded audio data"
    },
    "format": {
      "type": "string",
      "enum": ["wav", "mp3", "flac", "opus", "pcm16"],
      "description": "Audio format"
    }
  },
  "required": ["type"],
  "additionalProperties": false
}
