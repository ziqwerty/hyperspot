{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gts://gts.x.llmgw.core.response_resource.v1~",
  "title": "ResponseResource",
  "description": "Open Responses protocol response object",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique response identifier"
    },
    "object": {
      "type": "string",
      "const": "response",
      "description": "Object type discriminator"
    },
    "created_at": {
      "type": "integer",
      "minimum": 0,
      "description": "Unix timestamp of creation"
    },
    "completed_at": {
      "type": ["integer", "null"],
      "minimum": 0,
      "description": "Unix timestamp of completion"
    },
    "status": {
      "type": "string",
      "enum": ["queued", "in_progress", "completed", "incomplete", "failed"],
      "description": "Response lifecycle status"
    },
    "incomplete_details": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "reason": { "type": "string" }
          },
          "required": ["reason"],
          "additionalProperties": false
        },
        { "type": "null" }
      ],
      "description": "Details if status is incomplete"
    },
    "model": {
      "type": "string",
      "description": "Model used for generation"
    },
    "previous_response_id": {
      "type": ["string", "null"],
      "description": "ID of the previous response in a chain"
    },
    "instructions": {
      "type": ["string", "null"],
      "description": "System-level instructions (echoed back)"
    },
    "output": {
      "type": "array",
      "items": {
        "$ref": "gts://gts.x.llmgw.items.item.v1~"
      },
      "description": "Output items produced by the model"
    },
    "error": {
      "oneOf": [
        { "$ref": "gts://gts.x.llmgw.core.error.v1~" },
        { "type": "null" }
      ],
      "description": "Error details if status is failed"
    },
    "tools": {
      "type": "array",
      "items": {
        "$ref": "gts://gts.x.llmgw.tools.tool.v1~"
      },
      "description": "Tools available for this response"
    },
    "tool_choice": {
      "oneOf": [
        { "type": "string", "enum": ["auto", "required", "none"] },
        {
          "type": "object",
          "properties": {
            "type": { "type": "string", "const": "function" },
            "name": { "type": "string" }
          },
          "required": ["type", "name"]
        }
      ],
      "description": "Tool selection strategy"
    },
    "truncation": {
      "type": "string",
      "enum": ["auto", "disabled"],
      "description": "Context truncation strategy"
    },
    "parallel_tool_calls": {
      "type": "boolean",
      "description": "Whether parallel tool calls were enabled"
    },
    "text": {
      "$ref": "gts://gts.x.llmgw.core.text_format.v1~",
      "description": "Text format configuration"
    },
    "top_p": {
      "type": "number",
      "description": "Nucleus sampling parameter"
    },
    "presence_penalty": {
      "type": "number",
      "description": "Presence penalty"
    },
    "frequency_penalty": {
      "type": "number",
      "description": "Frequency penalty"
    },
    "top_logprobs": {
      "type": "integer",
      "description": "Number of top logprobs returned per token"
    },
    "temperature": {
      "type": "number",
      "description": "Sampling temperature"
    },
    "reasoning": {
      "$ref": "gts://gts.x.llmgw.core.reasoning_config.v1~",
      "description": "Reasoning configuration"
    },
    "usage": {
      "oneOf": [
        { "$ref": "gts://gts.x.llmgw.core.usage.v1~" },
        { "type": "null" }
      ],
      "description": "Token usage information. Null until response is completed."
    },
    "max_output_tokens": {
      "type": ["integer", "null"],
      "description": "Maximum output tokens"
    },
    "max_tool_calls": {
      "type": ["integer", "null"],
      "description": "Maximum number of tool calls"
    },
    "store": {
      "type": "boolean",
      "description": "Whether the response is stored"
    },
    "background": {
      "type": "boolean",
      "description": "Whether the response ran as a background job"
    },
    "service_tier": {
      "type": "string",
      "description": "Service tier used"
    },
    "metadata": {
      "type": ["object", "null"],
      "additionalProperties": { "type": "string" },
      "description": "Request metadata echoed back"
    },
    "safety_identifier": {
      "type": ["string", "null"],
      "description": "Safety configuration identifier"
    },
    "prompt_cache_key": {
      "type": ["string", "null"],
      "description": "Prompt cache key"
    }
  },
  "required": [
    "id", "object", "created_at", "completed_at", "status",
    "incomplete_details", "model", "previous_response_id",
    "instructions", "output", "error", "tools", "tool_choice",
    "truncation", "parallel_tool_calls", "text", "top_p",
    "presence_penalty", "frequency_penalty", "top_logprobs",
    "temperature", "reasoning", "usage", "max_output_tokens",
    "max_tool_calls", "store", "background", "service_tier",
    "metadata", "safety_identifier", "prompt_cache_key"
  ],
  "additionalProperties": false
}
