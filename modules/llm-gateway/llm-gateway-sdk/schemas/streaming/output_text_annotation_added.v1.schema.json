{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gts://gts.x.llmgw.streaming.event.v1~x.llmgw.streaming.output_text_annotation_added.v1~",
  "title": "Response output text annotation added event",
  "description": "A streaming event indicating an output text annotation was added.",
  "allOf": [
    { "$ref": "gts://gts.x.llmgw.streaming.event.v1~" },
    {
      "properties": {
        "type": {
          "type": "string",
          "const": "response.output_text.annotation.added"
        },
        "item_id": {
          "type": "string",
          "description": "The ID of the item that was updated."
        },
        "output_index": {
          "type": "integer",
          "description": "The index of the output item that was updated."
        },
        "content_index": {
          "type": "integer",
          "description": "The index of the output text content that was updated."
        },
        "annotation_index": {
          "type": "integer",
          "description": "The index of the annotation that was added."
        },
        "annotation": {
          "oneOf": [
            { "$ref": "gts://gts.x.llmgw.content.url_citation.v1~" },
            { "type": "null" }
          ],
          "description": "The annotation that was added."
        }
      },
      "required": ["type", "sequence_number", "item_id", "output_index", "content_index", "annotation_index", "annotation"]
    }
  ]
}
