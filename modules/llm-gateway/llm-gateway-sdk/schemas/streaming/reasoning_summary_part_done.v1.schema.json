{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gts://gts.x.llmgw.streaming.event.v1~x.llmgw.streaming.reasoning_summary_part_done.v1~",
  "title": "Response reasoning summary part done event",
  "description": "A streaming event indicating a reasoning summary part was completed.",
  "allOf": [
    { "$ref": "gts://gts.x.llmgw.streaming.event.v1~" },
    {
      "properties": {
        "type": {
          "type": "string",
          "const": "response.reasoning_summary_part.done"
        },
        "item_id": {
          "type": "string",
          "description": "The ID of the item that was updated."
        },
        "output_index": {
          "type": "integer",
          "minimum": 0,
          "description": "The index of the output item that was updated."
        },
        "summary_index": {
          "type": "integer",
          "minimum": 0,
          "description": "The index of the summary part that was completed."
        },
        "part": {
          "type": "object",
          "properties": {
            "type": { "type": "string", "const": "summary_text" },
            "text": { "type": "string" }
          },
          "required": ["type", "text"],
          "additionalProperties": false,
          "description": "The summary content part that was completed."
        }
      },
      "required": ["type", "sequence_number", "item_id", "output_index", "summary_index", "part"]
    }
  ]
}
